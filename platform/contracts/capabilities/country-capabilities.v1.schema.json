{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2fcompliant.org/capabilities/country-capabilities.v1.schema.json",
  "title": "D2F Country Capabilities v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["country", "packVersion", "effectiveFrom", "capabilities"],
  "properties": {
    "country": {"type": "string", "pattern": "^[A-Z]{2}$"},
    "packVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "effectiveFrom": {"type": "string", "format": "date"},
    "effectiveTo": {"type": ["string", "null"]},
    "sourcesVerifiedAt": {"type": ["string", "null"]},
    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"enum": ["unsupported", "preview", "qualified", "production", "suspended"]}
    }
  }
}
