{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.d2fcompliant.org/events/expense-submitted.v1.schema.json",
  "title": "ExpenseSubmitted v1",
  "allOf": [
    {"$ref": "event-envelope.v1.schema.json"},
    {"type": "object", "properties": {
      "eventType": {"const": "ExpenseSubmitted"},
      "eventVersion": {"const": 1},
      "eventCategory": {"const": "business"},
      "producer": {"type": "object", "properties": {"application": {"const": "d2f-expense"}}},
      "subject": {"type": "object", "properties": {"aggregateType": {"const": "ExpenseReport"}}},
      "payload": {"type": "object", "additionalProperties": false,
        "required": ["expenseReportId", "reportNumber", "claimantId", "currency", "totals", "lineCount"],
        "properties": {
          "expenseReportId": {"type": "string", "format": "uuid"},
          "reportNumber": {"type": "string", "minLength": 1},
          "claimantId": {"type": "string", "minLength": 1},
          "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
          "totals": {"type": "object", "additionalProperties": false, "required": ["net", "tax", "gross"], "properties": {
            "net": {"$ref": "#/$defs/decimal"}, "tax": {"$ref": "#/$defs/decimal"}, "gross": {"$ref": "#/$defs/decimal"}
          }},
          "lineCount": {"type": "integer", "minimum": 1}
        }
      }
    }}
  ],
  "$defs": {"decimal": {"type": "string", "pattern": "^-?[0-9]+(\\.[0-9]{1,6})?$"}}
}
